#!/bin/bash
set -eu
CPUS=$(grep -c ^processor /proc/cpuinfo)

# retrieved from https://nmap.org/dist/nmap-7.95.tar.bz2
# on Sun Dec  8 2024

VERSION=7.95
tar -xjvf nmap/nmap-${VERSION}.tar.bz2
cd nmap-${VERSION}
./configure
make prefix=${BOSH_INSTALL_TARGET} -j${CPUS}
make prefix=${BOSH_INSTALL_TARGET} install
