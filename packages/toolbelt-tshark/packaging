# Build Wireshark 4.4.2 - uses cmake instead of autotools
# https://www.wireshark.org/download/src/all-versions/wireshark-4.4.2.tar.xz
tar -xJf tshark/wireshark-4.4.2.tar.xz
(cd wireshark-4.4.2
 if command -v cmake >/dev/null 2>&1; then
   export C_INCLUDE_PATH="${BOSH_INSTALL_TARGET}/include"
   mkdir -p build && cd build
   cmake .. \
     -DCMAKE_INSTALL_PREFIX=${BOSH_INSTALL_TARGET} \
     -DBUILD_wireshark=OFF \
     -DBUILD_sharkd=OFF \
     -DBUILD_logray=OFF \
     -DENABLE_APPLICATION_BUNDLE=OFF \
     -DENABLE_QT=OFF \
     -DBUILD_randpkt=OFF && \
   make -j${CPUS} tshark && \
   make install
 else
   echo "ERROR: Wireshark 4.x requires cmake build system"
   exit 1
 fi
) || exit 1
