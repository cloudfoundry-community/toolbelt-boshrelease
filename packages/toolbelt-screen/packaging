#!/bin/bash
set -eu

# Man page: https://linux.die.net/man/1/screen
# Package docs: https://www.gnu.org/software/screen/
# Binary source: https://ftp.gnu.org/gnu/screen/screen-5.0.1.tar.gz


VERSION=5.0.1
tar xvzf screen/screen-${VERSION}.tar.gz
cd screen-${VERSION}
# --disable-pam: stemcell does not have PAM development headers
./configure --disable-pam
make prefix=${BOSH_INSTALL_TARGET} install
